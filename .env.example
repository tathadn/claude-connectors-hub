# Get your API key from https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_api_key_here

# Google OAuth access token for Gmail + Calendar MCP connectors
# Obtain via: npx @modelcontextprotocol/inspector → SSE → https://gmail.mcp.claude.com/mcp → Quick OAuth Flow
VITE_GOOGLE_TOKEN=your_google_oauth_token_here

# ⚠️  SECURITY WARNING:
# In production, NEVER expose your API key in client-side code.
# Route all API calls through a backend server instead.
# This client-side approach is for demonstration purposes only.
